# Frontend Environment Variables
# Copy to .env.local and adjust for your environment

# API URL - endpoint for 2wheels API (server-side, used in lib/api.ts)
# Production: https://cms.2wheels-rental.pl/api/2wheels
# Staging:    https://tst.2wheels-rental.pl/api/2wheels
# Local:      http://localhost:8080/api/2wheels
NEXT_PUBLIC_API_URL=https://cms.2wheels-rental.pl/api/2wheels

# API Domain - used for storage URLs (images, logos)
NEXT_PUBLIC_API_DOMAIN=https://cms.2wheels-rental.pl

# Backend URL - used by next.config.mjs rewrites (server-side only)
# This proxies /api/* and /storage/* requests to the backend
API_BACKEND_URL=https://cms.2wheels-rental.pl

# Tenant ID (multi-tenant support)
NEXT_PUBLIC_TENANT_ID=a0e1ef09-91b0-476a-aec1-45ae89c36bd4

# E2E Test URLs (Playwright)
E2E_FRONTEND_URL=https://2wheels-rental.pl
E2E_CMS_URL=https://cms.2wheels-rental.pl
