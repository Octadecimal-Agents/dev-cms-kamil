# Root "/" serves Next.js static homepage (index.html), not Laravel (index.php)
DirectoryIndex index.html

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # ── Handle Authorization Header ─────────────────────────────
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # ── Handle X-XSRF-Token Header ──────────────────────────────
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # ── Remove trailing slashes (unless it's a real directory) ──
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # ── Existing files → serve directly (BEFORE Laravel routes) ─
    # Static assets (_next/*, img/*, livewire/*.js, storage/*, etc.)
    # must be served by Apache without going through PHP.
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # ── Directories with index.html → serve directly ────────────
    # Handles "/" → index.html (Next.js homepage)
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_FILENAME}/index.html -f
    RewriteRule ^(.*)$ $1/index.html [L]

    # ── Clean URLs for static HTML pages ─────────────────────────
    # /regulamin → regulamin.html, /motocykle/slug → motocykle/slug.html
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+)$ $1.html [L]

    # ── Laravel routes: /admin, /api, /livewire, /sanctum, auth ─
    RewriteRule ^admin(/.*)?$ index.php [L]
    RewriteRule ^api(/.*)?$ index.php [L]
    RewriteRule ^livewire(/.*)?$ index.php [L]
    RewriteRule ^sanctum(/.*)?$ index.php [L]
    RewriteRule ^login$ index.php [L]
    RewriteRule ^logout$ index.php [L]
    RewriteRule ^up$ index.php [L]

    # ── Fallback → Laravel (catch-all) ──────────────────────────
    RewriteRule ^ index.php [L]
</IfModule>
