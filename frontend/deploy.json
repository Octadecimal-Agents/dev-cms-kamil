{
  "template": {
    "name": "2wheels",
    "version": "1.0.0",
    "description": "Motorcycle rental website template",
    "type": "nextjs",
    "ignore": false,
    "domain": "2wheels-rental.pl"
  },
  "environments": {
    "dev": {
      "enabled": true,
      "deployment": {
        "method": "ssh",
        "host": "51.83.253.165",
        "port": 22,
        "user": "debian",
        "path": "/var/www/2wheels_dev",
        "branch": "dev"
      },
      "build": {"command": "npm run build", "outputDir": ".next", "preInstall": "npm ci"},
      "env": {
        "NEXT_PUBLIC_API_URL": "https://dev.octadecimal.studio/api/2wheels_dev",
        "NEXT_PUBLIC_API_DOMAIN": "https://dev.octadecimal.studio",
        "NODE_ENV": "production"
      },
      "secrets": {"TENANT_ID": "{{ ask:tenant_id }}"},
      "pm2": {"enabled": true, "name": "2wheels-dev", "instances": 1, "execMode": "cluster"},
      "nginx": {
        "enabled": true,
        "domain": "dev.2wheels-rental.pl",
        "port": 3001,
        "ssl": true
      }
    },
    "tst": {
      "enabled": true,
      "deployment": {
        "method": "ssh",
        "host": "51.83.253.165",
        "port": 22,
        "user": "debian",
        "path": "/var/www/2wheels_tst",
        "branch": "main"
      },
      "build": {"command": "npm run build", "outputDir": ".next", "preInstall": "npm ci"},
      "env": {
        "NEXT_PUBLIC_API_URL": "https://dev.octadecimal.studio/api/2wheels_tst",
        "NEXT_PUBLIC_API_DOMAIN": "https://dev.octadecimal.studio",
        "NODE_ENV": "production"
      },
      "secrets": {"TENANT_ID": "{{ ask:tenant_id }}"},
      "pm2": {"enabled": true, "name": "2wheels-tst", "instances": 2, "execMode": "cluster"},
      "nginx": {
        "enabled": true,
        "domain": "tst.2wheels-rental.pl",
        "port": 3002,
        "ssl": true
      }
    },
    "prd": {
      "enabled": true,
      "deployment": {
        "method": "ssh",
        "host": "51.83.253.165",
        "port": 22,
        "user": "debian",
        "path": "/var/www/2wheels_prd",
        "branch": "main"
      },
      "build": {"command": "npm run build", "outputDir": ".next", "preInstall": "npm ci"},
      "env": {
        "NEXT_PUBLIC_API_URL": "https://dev.octadecimal.studio/api/2wheels",
        "NEXT_PUBLIC_API_DOMAIN": "https://dev.octadecimal.studio",
        "NEXT_PUBLIC_TENANT_ID": "a0e1ef09-91b0-476a-aec1-45ae89c36bd4",
        "NEXT_PUBLIC_CMS_URL": "https://dev.octadecimal.studio",
        "NEXT_PUBLIC_BASE_PATH": "",
        "NODE_ENV": "production"
      },
      "secrets": {"TENANT_ID": "{{ ask:tenant_id }}"},
      "pm2": {"enabled": true, "name": "2wheels-prd", "instances": 1, "execMode": "fork", "script": ".next/standalone/server.js"},
      "nginx": {
        "enabled": true,
        "domain": "2wheels-rental.pl",
        "port": 3003,
        "ssl": true
      }
    }
  }
}
